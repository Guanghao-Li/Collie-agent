# Copy this file to .env, then fill in your real values.
# .env is ignored by git, so secrets stay local.

# Discord
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_DEFAULT_PUSH_CHANNEL_ID=

# Main LLM provider.
# Keep config.toml as provider = "echo" if you do not want to call a real model yet.
# For OpenAI-compatible vendors, set provider = "openai-compatible" in config.toml.
LLM_MODEL=
LLM_BASE_URL=
LLM_API_KEY=

# Optional fast model for lightweight internal tasks.
FAST_LLM_API_KEY=
